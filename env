# Template for local .env file — copy to .env and fill in your keys.
# The .env file is gitignored; this template (with empty values) is safe to commit.

# Anthropic API Key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# LLM provider: "anthropic" (default), "openai", or "ollama"
LLM_PROVIDER=anthropic

# Ollama settings (used when LLM_PROVIDER=ollama) — OpenAI-compatible endpoint.
# Works for local Ollama or Ollama Cloud; just change the endpoint + key:
#   Local:  OLLAMA_BASE_URL=http://localhost:11434/v1   OLLAMA_API_KEY=ollama
#   Cloud:  OLLAMA_BASE_URL=https://ollama.com/v1        OLLAMA_API_KEY=<your ollama cloud key>
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# Model used for all tiers; optionally override per-tier with
# OLLAMA_MODEL_OPUS / OLLAMA_MODEL_SONNET / OLLAMA_MODEL_HAIKU
OLLAMA_MODEL=qwen2.5:7b
# LangSmith tracing — add your API key from smith.langchain.com
LANGCHAIN_API_KEY=
# set to true to enable LangSmith tracing (requires LANGCHAIN_API_KEY)
LANGCHAIN_TRACING_V2=false
# leave these
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
TOKENIZERS_PARALLELISM=false
